#!/usr/bin/env bash
# ==============================================================================
# gituser - Git Identity Manager
# Switches Git name, email, and SSH key per repository with a single command.
#
# Repository: https://github.com/NWGKGIT/git-identity-manager
# ==============================================================================

set -euo pipefail

readonly VERSION="1.0.0"
readonly CONFIG_FILE="${GIT_PROFILES:-$HOME/.git-profiles}"

# ==============================================================================
# Output helpers
# ==============================================================================

# Enable colors only when stdout is a terminal
if [[ -t 1 ]]; then
    C_RED='\033[0;31m'
    C_GREEN='\033[0;32m'
    C_YELLOW='\033[1;33m'
    C_BLUE='\033[0;34m'
    C_BOLD='\033[1m'
    C_RESET='\033[0m'
else
    C_RED='' C_GREEN='' C_YELLOW='' C_BLUE='' C_BOLD='' C_RESET=''
fi

err()  { printf "${C_RED}error:${C_RESET} %s\n" "$*" >&2; }
ok()   { printf "${C_GREEN}ok:${C_RESET} %s\n" "$*"; }
info() { printf "${C_BLUE}-->${C_RESET} %s\n" "$*"; }
warn() { printf "${C_YELLOW}warning:${C_RESET} %s\n" "$*"; }
bold() { printf "${C_BOLD}%s${C_RESET}\n" "$*"; }
die()  { err "$*"; exit 1; }

# ==============================================================================
# Config helpers
# ==============================================================================

profile_exists() {
    grep -q "^\[$1\]$" "$CONFIG_FILE" 2>/dev/null
}

# Read a single named field from a profile section.
# Usage: _field <profile-name> <field-name>
_field() {
    local profile="$1" field="$2"
    awk -v p="[$profile]" -v f="$field" '
        $0==p           { found=1; next }
        /^\[/           { if(found) exit }
        found && /=/ {
            eq  = index($0, "=")
            key = substr($0, 1, eq-1)
            val = substr($0, eq+1)
            gsub(/^[ \t]+|[ \t]+$/, "", key)
            gsub(/^[ \t]+|[ \t]+$/, "", val)
            if (key == f) { print val; exit }
        }
    ' "$CONFIG_FILE"
}

# Populate p_name, p_email, p_ssh for a given profile name.
# Variables are set in the caller's scope.
read_profile() {
    p_name=$(_field "$1" "name")
    p_email=$(_field "$1" "email")
    p_ssh=$(_field "$1" "ssh_key")
}

list_profiles() {
    grep '^\[.*\]$' "$CONFIG_FILE" 2>/dev/null | tr -d '[]'
}

remove_profile_section() {
    local profile="$1"
    local tmpfile
    tmpfile=$(mktemp)
    awk -v p="[$profile]" '
        $0==p  { skip=1; next }
        /^\[/  { if(skip) skip=0 }
        !skip  { print }
    ' "$CONFIG_FILE" > "$tmpfile"
    mv "$tmpfile" "$CONFIG_FILE"
}

expand_tilde() {
    echo "${1/#\~/$HOME}"
}

no_profiles() {
    [[ ! -f "$CONFIG_FILE" ]] || ! grep -q '^\[' "$CONFIG_FILE" 2>/dev/null
}

# ==============================================================================
# SSH helpers
# ==============================================================================

find_ssh_private_keys() {
    # Print paths to private keys that have a matching *.pub file
    find "$HOME/.ssh" -maxdepth 1 -name "*.pub" 2>/dev/null | sort | while IFS= read -r pubkey; do
        local privkey="${pubkey%.pub}"
        [[ -f "$privkey" ]] && echo "$privkey"
    done
}

try_copy_to_clipboard() {
    local file="$1"
    if command -v xclip &>/dev/null; then
        xclip -selection clipboard < "$file" && return 0
    elif command -v xsel &>/dev/null; then
        xsel --clipboard --input < "$file" && return 0
    elif command -v pbcopy &>/dev/null; then
        pbcopy < "$file" && return 0
    fi
    return 1
}

# ==============================================================================
# SSH key generation sub-wizard
# ==============================================================================

_wizard_generate_ssh_key() {
    local profile_name="$1"
    local default_email="$2"

    echo ""
    echo "No SSH key found. Let's generate one."
    echo ""

    local key_email
    read -r -p "Email address for the SSH key [$default_email]: " key_email
    key_email="${key_email:-$default_email}"

    local key_path="$HOME/.ssh/id_ed25519_${profile_name}"

    echo ""
    info "Running: ssh-keygen -t ed25519 -C \"$key_email\" -f \"$key_path\""
    echo ""

    ssh-keygen -t ed25519 -C "$key_email" -f "$key_path"

    echo ""
    echo "Public key (${key_path}.pub):"
    echo ""
    cat "${key_path}.pub"
    echo ""

    if try_copy_to_clipboard "${key_path}.pub"; then
        info "Public key copied to clipboard."
    fi

    echo ""
    echo "Add this key to your GitHub account:"
    echo "  https://github.com/settings/ssh/new"
    echo ""
    read -r -p "Press Enter once the key has been added to GitHub..."

    # Return the key path to the caller via stdout
    echo "$key_path"
}

# ==============================================================================
# Profile creation wizard  (shared by 'init' and 'add')
# ==============================================================================

wizard_create_profile() {
    local profile_name git_name git_email git_ssh

    # -- Profile name --
    while true; do
        read -r -p "Profile name (e.g. work, personal): " profile_name
        [[ -n "$profile_name" ]]         || { err "Profile name cannot be empty."; continue; }
        ! profile_exists "$profile_name" || { err "Profile '$profile_name' already exists. Use 'gituser edit $profile_name' to modify it."; continue; }
        break
    done

    # -- Git identity --
    while true; do
        read -r -p "Git name: " git_name
        [[ -n "$git_name" ]] || { err "Git name cannot be empty."; continue; }
        break
    done

    while true; do
        read -r -p "Git email: " git_email
        [[ -n "$git_email" ]] || { err "Git email cannot be empty."; continue; }
        break
    done

    # -- SSH key --
    echo ""
    echo "SSH key setup"
    echo "-------------"

    git_ssh=""

    local existing_keys=()
    while IFS= read -r key; do
        existing_keys+=("$key")
    done < <(find_ssh_private_keys)

    if [[ ${#existing_keys[@]} -gt 0 ]]; then
        read -r -p "Associate an SSH key with this profile? (y/n): " want_ssh
        if [[ "$want_ssh" =~ ^[yY]$ ]]; then
            echo ""
            local i
            for i in "${!existing_keys[@]}"; do
                printf "  %d) %s\n" "$((i+1))" "${existing_keys[$i]}"
            done
            printf "  %d) Enter a custom path\n" "$((${#existing_keys[@]}+1))"
            printf "  0) Skip\n"
            echo ""

            local choice
            read -r -p "Select [1]: " choice
            choice="${choice:-1}"

            if [[ "$choice" -eq 0 ]]; then
                git_ssh=""
            elif [[ "$choice" -le "${#existing_keys[@]}" ]]; then
                git_ssh="${existing_keys[$((choice-1))]}"
            else
                read -r -p "Path to SSH key: " git_ssh
            fi
        fi
    else
        read -r -p "Do you have an SSH key for this profile? (y/n): " has_ssh
        if [[ "$has_ssh" =~ ^[yY]$ ]]; then
            read -r -p "Path to SSH key (e.g. ~/.ssh/id_ed25519): " git_ssh
        else
            # Generate a new key; capture the returned path
            git_ssh=$(_wizard_generate_ssh_key "$profile_name" "$git_email")
        fi
    fi

    # -- Write to config --
    {
        echo ""
        echo "[$profile_name]"
        echo "name = $git_name"
        echo "email = $git_email"
        [[ -n "$git_ssh" ]] && echo "ssh_key = $git_ssh"
    } >> "$CONFIG_FILE"

    echo ""
    ok "Profile '$profile_name' saved."
}

# ==============================================================================
# Commands
# ==============================================================================

cmd_init() {
    echo ""
    bold "Git Identity Manager - Setup"
    echo ""
    echo "This tool switches your Git name, email, and SSH key per repository"
    echo "with a single command. No manual config editing needed."
    echo ""
    printf '%0.s-' {1..60}; echo ""

    local adding=true
    while $adding; do
        wizard_create_profile
        echo ""
        read -r -p "Add another profile? (y/n) [n]: " more
        [[ "$more" =~ ^[yY]$ ]] || adding=false
    done

    echo ""
    printf '%0.s-' {1..60}; echo ""
    echo ""
    bold "Setup complete."
    echo ""
    echo "Usage:"
    echo "  gituser use <profile>            switch identity in current repo"
    echo "  gituser use <profile> --global   switch identity globally"
    echo "  gituser status                   show current identity"
    echo "  gituser list                     list all profiles"
    echo "  gituser clone <url>              clone a repo and apply a profile"
    echo ""
    echo "Run 'gituser help' for all commands."
    echo ""
}

cmd_status() {
    local in_repo=false
    git rev-parse --is-inside-work-tree &>/dev/null && in_repo=true

    echo ""
    bold "Current Git Identity"
    echo ""

    if $in_repo; then
        local scope
        if git config --local user.name &>/dev/null 2>&1; then
            scope="local (this repo)"
        else
            scope="global"
        fi
        printf "  Scope:  %s\n" "$scope"
        printf "  Name:   %s\n" "$(git config user.name 2>/dev/null || echo '(not set)')"
        printf "  Email:  %s\n" "$(git config user.email 2>/dev/null || echo '(not set)')"
        local ssh_cmd
        ssh_cmd=$(git config core.sshCommand 2>/dev/null || true)
        printf "  SSH:    %s\n" "${ssh_cmd:-(default)}"
    else
        printf "  Scope:  %s\n" "global (not inside a repo)"
        printf "  Name:   %s\n" "$(git config --global user.name 2>/dev/null || echo '(not set)')"
        printf "  Email:  %s\n" "$(git config --global user.email 2>/dev/null || echo '(not set)')"
        local ssh_cmd
        ssh_cmd=$(git config --global core.sshCommand 2>/dev/null || true)
        printf "  SSH:    %s\n" "${ssh_cmd:-(default)}"
    fi

    # Show which saved profile matches the current identity (by email)
    if [[ -f "$CONFIG_FILE" ]]; then
        local current_email
        current_email=$(git config user.email 2>/dev/null || true)
        if [[ -n "$current_email" ]]; then
            local p_name="" p_email="" p_ssh=""
            while IFS= read -r profile; do
                read_profile "$profile"
                if [[ "$p_email" == "$current_email" ]]; then
                    echo ""
                    printf "  Matches profile: %s\n" "$profile"
                    break
                fi
            done < <(list_profiles)
        fi
    fi

    echo ""
}

cmd_list() {
    if no_profiles; then
        echo "No profiles configured. Run 'gituser init' to get started."
        return 0
    fi

    echo ""
    bold "Saved profiles"
    echo ""

    local p_name="" p_email="" p_ssh=""
    while IFS= read -r profile; do
        read_profile "$profile"
        printf "  %-20s %s <%s>\n" "$profile" "$p_name" "$p_email"
        [[ -n "$p_ssh" ]] && printf "  %-20s SSH: %s\n" "" "$p_ssh"
    done < <(list_profiles)

    echo ""
}

cmd_use() {
    local profile="" scope="--local"

    for arg in "$@"; do
        case "$arg" in
            --global) scope="--global" ;;
            -*)       die "Unknown flag: $arg" ;;
            *)        profile="$arg" ;;
        esac
    done

    [[ -n "$profile" ]] || die "Usage: gituser use <profile> [--global]"

    if [[ "$scope" == "--local" ]]; then
        git rev-parse --is-inside-work-tree &>/dev/null \
            || die "Not inside a Git repository. Use '--global' to apply globally."
    fi

    if ! profile_exists "$profile"; then
        err "Profile '$profile' not found."
        info "Run 'gituser list' to see available profiles."
        exit 1
    fi

    local p_name="" p_email="" p_ssh=""
    read_profile "$profile"

    # shellcheck disable=SC2086
    git config $scope user.name  "$p_name"
    # shellcheck disable=SC2086
    git config $scope user.email "$p_email"

    if [[ -n "$p_ssh" ]]; then
        local expanded
        expanded=$(expand_tilde "$p_ssh")
        # shellcheck disable=SC2086
        git config $scope core.sshCommand "ssh -i $expanded -o IdentitiesOnly=yes"
    else
        # shellcheck disable=SC2086
        git config $scope --unset core.sshCommand 2>/dev/null || true
    fi

    echo ""
    ok "Switched to profile '$profile' ($scope)."
    printf "  Name:  %s\n" "$p_name"
    printf "  Email: %s\n" "$p_email"
    [[ -n "$p_ssh" ]] && printf "  SSH:   %s\n" "$p_ssh"
    echo ""
}

cmd_add() {
    echo ""
    bold "Add Profile"
    wizard_create_profile
    echo ""
}

cmd_edit() {
    local profile="${1:-}"
    [[ -n "$profile" ]] || die "Usage: gituser edit <profile>"
    profile_exists "$profile" || die "Profile '$profile' not found."

    local p_name="" p_email="" p_ssh=""
    read_profile "$profile"

    echo ""
    bold "Edit profile: $profile"
    echo "Press Enter to keep the current value shown in [brackets]."
    echo ""

    local new_name new_email new_ssh

    read -r -p "Git name [$p_name]: " new_name
    new_name="${new_name:-$p_name}"

    read -r -p "Git email [$p_email]: " new_email
    new_email="${new_email:-$p_email}"

    read -r -p "SSH key path [$p_ssh]: " new_ssh
    new_ssh="${new_ssh:-$p_ssh}"

    remove_profile_section "$profile"
    {
        echo ""
        echo "[$profile]"
        echo "name = $new_name"
        echo "email = $new_email"
        [[ -n "$new_ssh" ]] && echo "ssh_key = $new_ssh"
    } >> "$CONFIG_FILE"

    echo ""
    ok "Profile '$profile' updated."
    echo ""
}

cmd_rename() {
    local old_name="${1:-}" new_name="${2:-}"
    [[ -n "$old_name" && -n "$new_name" ]] || die "Usage: gituser rename <old-name> <new-name>"
    profile_exists "$old_name"  || die "Profile '$old_name' not found."
    ! profile_exists "$new_name" || die "Profile '$new_name' already exists."

    local tmpfile
    tmpfile=$(mktemp)
    awk -v old="[$old_name]" -v new="[$new_name]" '
        $0==old { print new; next }
        { print }
    ' "$CONFIG_FILE" > "$tmpfile"
    mv "$tmpfile" "$CONFIG_FILE"

    ok "Renamed profile '$old_name' to '$new_name'."
}

cmd_remove() {
    local profile="${1:-}"
    [[ -n "$profile" ]] || die "Usage: gituser remove <profile>"
    profile_exists "$profile" || die "Profile '$profile' not found."

    read -r -p "Remove profile '$profile'? This cannot be undone. (y/n): " confirm
    [[ "$confirm" =~ ^[yY]$ ]] || { echo "Cancelled."; return 0; }

    remove_profile_section "$profile"
    ok "Profile '$profile' removed."
}

cmd_clone() {
    local url="" dir="" profile=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --as)
                shift
                [[ -n "${1:-}" ]] || die "--as requires a profile name"
                profile="$1"
                ;;
            *)
                if   [[ -z "$url" ]]; then url="$1"
                elif [[ -z "$dir" ]]; then dir="$1"
                fi
                ;;
        esac
        shift
    done

    [[ -n "$url" ]] || die "Usage: gituser clone <url> [directory] [--as <profile>]"
    [[ -n "$dir" ]] || dir=$(basename "$url" .git)

    info "Cloning $url..."
    git clone "$url" "$dir"

    # Pick profile interactively if not specified via --as
    if [[ -z "$profile" ]] && ! no_profiles; then
        local count
        count=$(list_profiles | wc -l | tr -d ' ')
        if [[ "$count" -eq 1 ]]; then
            profile=$(list_profiles)
            info "Applying profile '$profile'..."
        else
            echo ""
            cmd_list
            read -r -p "Which profile for this repo? (leave blank to skip): " profile
        fi
    fi

    if [[ -n "$profile" ]]; then
        (cd "$dir" && gituser use "$profile")
    fi

    echo ""
    echo "Cloned to: $dir"
    [[ -n "$profile" ]] && echo "Profile:   $profile"
    echo ""
}

cmd_doctor() {
    echo ""
    bold "Git Identity Doctor"
    echo ""

    local issues=0

    printf "  git:         %s\n" "$(git --version)"
    printf "  config file: %s\n" "$CONFIG_FILE"

    if [[ ! -f "$CONFIG_FILE" ]]; then
        warn "Config file not found. Run 'gituser init'."
        ((issues++))
    elif no_profiles; then
        warn "No profiles configured. Run 'gituser init'."
        ((issues++))
    else
        echo ""
        printf "  Profiles:\n"
        local p_name="" p_email="" p_ssh=""
        while IFS= read -r profile; do
            read_profile "$profile"
            if [[ -n "$p_ssh" ]]; then
                local expanded
                expanded=$(expand_tilde "$p_ssh")
                if [[ -f "$expanded" ]]; then
                    printf "    %-18s  %-30s  SSH: OK\n" "$profile" "<$p_email>"
                else
                    printf "    %-18s  %-30s  SSH: key not found (%s)\n" "$profile" "<$p_email>" "$p_ssh"
                    ((issues++))
                fi
            else
                printf "    %-18s  %-30s  SSH: not configured\n" "$profile" "<$p_email>"
            fi
        done < <(list_profiles)
    fi

    echo ""
    if [[ $issues -eq 0 ]]; then
        ok "All checks passed."
    else
        warn "$issues issue(s) found. See above for details."
    fi
    echo ""
}

cmd_help() {
    echo ""
    bold "gituser - Git Identity Manager v${VERSION}"
    echo ""
    echo "Switch your Git name, email, and SSH key per repository with a single command."
    echo ""
    echo "Usage: gituser <command> [options]"
    echo ""
    echo "Commands:"
    printf "  %-34s %s\n" "init"                         "Run the setup wizard"
    printf "  %-34s %s\n" "status"                       "Show the current Git identity"
    printf "  %-34s %s\n" "list"                         "List all saved profiles"
    printf "  %-34s %s\n" "use <profile>"                "Apply a profile to the current repo"
    printf "  %-34s %s\n" "use <profile> --global"       "Apply a profile globally"
    printf "  %-34s %s\n" "add"                          "Add a new profile interactively"
    printf "  %-34s %s\n" "edit <profile>"               "Edit an existing profile"
    printf "  %-34s %s\n" "rename <old-name> <new-name>" "Rename a profile"
    printf "  %-34s %s\n" "remove <profile>"             "Remove a profile"
    printf "  %-34s %s\n" "clone <url> [dir]"            "Clone a repo and apply a profile"
    printf "  %-34s %s\n" "clone <url> --as <profile>"   "Clone and apply a specific profile"
    printf "  %-34s %s\n" "doctor"                       "Check configuration health"
    printf "  %-34s %s\n" "version"                      "Print version"
    printf "  %-34s %s\n" "help"                         "Show this message"
    echo ""
    printf "Config file: %s\n" "$CONFIG_FILE"
    echo "  Override:  GIT_PROFILES=/path/to/file gituser ..."
    echo ""
}

# ==============================================================================
# Main
# ==============================================================================

if ! command -v git &>/dev/null; then
    die "git is not installed or not in PATH."
fi

CMD="${1:-help}"
shift || true

# Auto-init: when no profiles are configured, prompt to run setup wizard.
# Commands that don't require profiles are excluded.
case "$CMD" in
    init|help|--help|-h|version|--version|-v|doctor) ;;
    *)
        if no_profiles; then
            echo ""
            warn "No profiles configured."
            read -r -p "Run 'gituser init' now? (y/n) [y]: " run_init
            run_init="${run_init:-y}"
            if [[ "$run_init" =~ ^[yY]$ ]]; then
                cmd_init
                exit 0
            fi
            echo ""
        fi
        ;;
esac

case "$CMD" in
    init)              cmd_init    "$@" ;;
    status)            cmd_status  "$@" ;;
    list)              cmd_list    "$@" ;;
    use)               cmd_use     "$@" ;;
    add)               cmd_add     "$@" ;;
    edit)              cmd_edit    "$@" ;;
    rename)            cmd_rename  "$@" ;;
    remove)            cmd_remove  "$@" ;;
    clone)             cmd_clone   "$@" ;;
    doctor)            cmd_doctor  "$@" ;;
    version|--version|-v) printf "gituser %s\n" "$VERSION" ;;
    help|--help|-h)    cmd_help ;;
    *) err "Unknown command: $CMD"; info "Run 'gituser help' for usage."; exit 1 ;;
esac
